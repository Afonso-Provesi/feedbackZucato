# Email para 2FA e recuperacao de senha
# Gmail exige senha de app de 16 caracteres. A senha normal da conta nao funciona.
RECOVERY_SMTP_HOST=smtp.gmail.com
RECOVERY_SMTP_PORT=587
RECOVERY_SMTP_USER=zucatorecovery@gmail.com
RECOVERY_SMTP_PASS=sua_senha_de_app_do_gmail
RECOVERY_SMTP_FROM="Clinica Zucato <zucatorecovery@gmail.com>"

# Email para alertas de seguranca
# Se ficar vazio, o sistema reutiliza automaticamente o bloco RECOVERY_SMTP_*.
SECURITY_ALERT_SMTP_HOST=
SECURITY_ALERT_SMTP_PORT=587
SECURITY_ALERT_SMTP_USER=
SECURITY_ALERT_SMTP_PASS=
SECURITY_ALERT_SMTP_FROM=
SECURITY_ALERT_EMAILS=zucatorecovery@gmail.com

# Compatibilidade com o setup antigo
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin Auth
ADMIN_SECRET=your_secure_admin_secret

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000

# Environment
NODE_ENV=development
ALLOW_DEV_2FA_FALLBACK=false

# Ads (Google AdSense)
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# multiple slots can be defined on the Vercel dashboard as secrets
# NEXT_PUBLIC_ADSENSE_SLOT_HOME=1234567890

# Theme Configuration
NEXT_PUBLIC_THEME=zucato
